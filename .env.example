# Copy to .env and fill in values before running `docker compose up`.
# All `REQUIRED` values must be set — compose will refuse to start otherwise.

# REQUIRED — PostgreSQL password for the database container.
# Generate one with: openssl rand -base64 24
POSTGRES_PASSWORD=

# REQUIRED — Secret used for session signing and WOPI access-token HMAC.
# Must be 16+ characters. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Port to expose the app on (default: 5000)
APP_PORT=5000

# --- Bootstrap admin (seeded automatically at container start) ---
# When both EMAIL and PASSWORD are set, the app container seeds this account
# as an admin before starting. Idempotent: bringing the stack up again with
# the same email rotates that account's password and re-promotes it to admin
# (recovery path if you forget the password).
# Leave blank to seed manually via:
#   docker compose exec app node scripts/dist/create-admin.mjs --email … --password …
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_NAME=

# --- LibreOffice (Collabora Online) editor ---

# Public URL where END USERS' BROWSERS reach Collabora.
#
# DEFAULT (recommended): leave this blank. The app reverse-proxies Collabora
# at `${PUBLIC_URL}/collabora` automatically — no extra vhost, no extra TLS
# cert, no NPM/Caddy/nginx config. Whatever proxy already routes traffic to
# the `app` container will also serve Collabora because it's the same domain
# and same WS upgrade path that already works for /api/ws/*.
#
# OVERRIDE only if you want Collabora on a separate hostname (e.g. you're
# running a multi-tenant Collabora cluster). Then point this at a vhost you
# manage yourself, ensure WebSockets are enabled, and TLS is terminated.
#COLLABORA_URL=https://office.your-domain.tld

# URL Collabora uses to call BACK into this app over the docker network.
# Leave as http://app:5000 when using docker-compose (it's the in-network alias).
# Only change if you run the app outside compose.
WOPI_PUBLIC_URL=http://app:5000

# In-network URL the *app* uses to reach the Collabora container (the proxy
# upstream). Leave as the default unless you renamed the compose service.
#COLLABORA_UPSTREAM_URL=http://collabora:9980

# Port to expose Collabora on (default: 9980).
# By default Collabora binds to 127.0.0.1 only — set COLLABORA_BIND=0.0.0.0 to expose externally
# (only do this behind a TLS reverse proxy).
COLLABORA_PORT=9980
COLLABORA_BIND=127.0.0.1

# REQUIRED — Collabora admin console credentials (http://localhost:9980/browser/dist/admin/admin.html)
# Generate password with: openssl rand -base64 24
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=

# REQUIRED — Public URL of this app. Used to build OIDC redirect URIs and
# absolute share links. MUST match what the user's browser sees.
# Local testing: http://localhost:5000. Production: https://studio.your-domain.tld
PUBLIC_URL=

# --- Authentik (OIDC) — OPTIONAL ---
# Leave all three blank to run with local accounts only (signup/login via the
# create-admin script + the in-app admin signup endpoint).
# To enable "Continue with Authentik" on the login page, set ALL THREE:
# - Client type: Confidential
# - Redirect URI: <PUBLIC_URL>/api/auth/callback
# - Scopes: openid, profile, email
AUTHENTIK_ISSUER=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Authentik has no built-in "verify-on-signup" flow, so admin-created users
# arrive with email_verified=false (or omitted) and Cue's strict OIDC gate
# rejects them with "Verify your email". When you control Authentik and
# enrollment is admin-only, that gate is redundant — set this to `true`
# to skip it for Authentik sign-ins only (Google sign-ins stay strict).
# Set OIDC_TRUST_UNVERIFIED_EMAIL=true instead to skip for ALL providers.
AUTHENTIK_TRUST_UNVERIFIED_EMAIL=
# OIDC_TRUST_UNVERIFIED_EMAIL=

# --- Google (OIDC) — OPTIONAL ---
# Adds a "Continue with Google" button to the login page. Set both CLIENT_ID
# and CLIENT_SECRET; leave blank to disable.
#
# Setup (one-time, free — no Workspace required):
#   1. https://console.cloud.google.com → create or select a project.
#   2. APIs & Services → OAuth consent screen
#      • User type: External
#      • App name, support email, your PUBLIC_URL as homepage
#      • Privacy policy URL: <PUBLIC_URL>/privacy   (ships with the app)
#      • Scopes: openid, /auth/userinfo.email, /auth/userinfo.profile
#      • Click "Publish app" (Testing → In production). No verification is
#        required for these non-sensitive scopes — any Google account can
#        then complete the flow.
#   3. APIs & Services → Credentials → Create OAuth Client ID
#      • Application type: Web application
#      • Authorized redirect URI: <PUBLIC_URL>/api/auth/google/callback
#   4. Copy the Client ID + Secret here.
#
# Sign-in policy: NEW Google logins are INVITE-ONLY (an admin must first add
# a /members row with the user's email) AND land inactive (an admin must
# approve them in /admin/users) — see replit.md "Authentication".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: restrict to a single Google Workspace domain (e.g. acme.com).
# Leave blank to allow any Google account that an admin has invited.
GOOGLE_HOSTED_DOMAIN=

# --- Email notifications (SendGrid) ---
# Optional. When SENDGRID_API_KEY + EMAIL_FROM are both set, Cue sends email
# notifications for project and task lifecycle events to project members, and
# the share dialog gains a "Send link via email" form.
# When either is unset, the app runs as before — email sends are silently
# skipped (logged at info level), and the share dialog hides the email form.
#
# Get an API key from https://app.sendgrid.com/settings/api_keys (Mail Send
# permission). EMAIL_FROM must be a sender address you've verified with
# SendGrid (Single Sender Verification or a verified domain).
SENDGRID_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=Cue
