# Copy to .env and fill in values before running `docker compose up`.
# All `REQUIRED` values must be set — compose will refuse to start otherwise.

# REQUIRED — PostgreSQL password for the database container.
# Generate one with: openssl rand -base64 24
POSTGRES_PASSWORD=

# REQUIRED — Secret used for session signing and WOPI access-token HMAC.
# Must be 16+ characters. Generate with: openssl rand -base64 32
SESSION_SECRET=

# Port to expose the app on (default: 5000)
APP_PORT=5000

# --- LibreOffice (Collabora Online) editor ---

# Public URL where end users' browsers reach Collabora.
# Local testing: http://localhost:9980. Production: https://office.your-domain.tld (TLS reverse proxy required).
COLLABORA_URL=http://localhost:9980

# URL Collabora uses to call back into this app over the docker network.
# Leave as http://app:5000 when using docker-compose.
WOPI_PUBLIC_URL=http://app:5000

# Port to expose Collabora on (default: 9980).
# By default Collabora binds to 127.0.0.1 only — set COLLABORA_BIND=0.0.0.0 to expose externally
# (only do this behind a TLS reverse proxy).
COLLABORA_PORT=9980
COLLABORA_BIND=127.0.0.1

# REQUIRED — Collabora admin console credentials (http://localhost:9980/browser/dist/admin/admin.html)
# Generate password with: openssl rand -base64 24
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=

# --- Authentik (OIDC) ---
# REQUIRED — Public URL of this app, used as the OIDC redirect base.
# Local testing: http://localhost:5000. Production: https://studio.your-domain.tld
PUBLIC_URL=

# REQUIRED — Authentik OIDC provider settings. Create an OAuth2/OpenID Provider in Authentik:
# - Client type: Confidential
# - Redirect URI: <PUBLIC_URL>/api/auth/callback
# - Scopes: openid, profile, email
# Then assign it to an Application and copy the values below.
AUTHENTIK_ISSUER=https://auth.your-domain.tld/application/o/studio-command/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
